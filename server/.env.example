# Copy to .env and fill in values. Never commit .env.

# Neon — use direct host or pooler (-pooler in hostname) for server apps
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated browser origins allowed to call this API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# At least one LLM key required for chat
OPENAI_API_KEY=
# Same model is used for streaming coach + JSON agents (intent, chips, memory, summary)
OPENAI_MODEL=gpt-4.1-mini

# Fallback when OpenAI fails or is unset (OpenAI-compatible Groq API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Guardrails: max user message length, /chat/stream RPM per user, JSON LLM retries
# GUARDRAIL_MAX_MESSAGE_CHARS=2000
# GUARDRAIL_RATE_LIMIT_PER_MINUTE=10
# GUARDRAIL_JSON_RETRIES=2
